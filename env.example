VITE_API_BASE_URL=https://example.execute-api.us-east-1.amazonaws.com
VITE_STREAM_WS_URL=wss://example.execute-api.us-east-1.amazonaws.com/stream
VITE_RELEASE_CHANNEL=dev

# Stream biography chat replies over the WebSocket (route "biography.stream").
# Off by default; biography chat uses HTTP until this is "true" AND the backend
# KININ_BIOGRAPHY_STREAMING_ENABLED flag + WS route are deployed.
VITE_BIOGRAPHY_STREAMING_ENABLED=false

VITE_COGNITO_USER_POOL_ID=us-east-1_example
VITE_COGNITO_USER_POOL_CLIENT_ID=exampleclientid
VITE_COGNITO_DOMAIN=example.auth.us-east-1.amazoncognito.com
VITE_REDIRECT_SIGNIN=http://localhost:5173/
VITE_REDIRECT_SIGNOUT=http://localhost:5173/

# Optional Google social login button in UI.
VITE_GOOGLE_LOGIN_ENABLED=0
VITE_GOOGLE_PROVIDER_NAME=Google
